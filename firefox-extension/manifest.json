{
  "manifest_version": 3,
  "name": "GNOME Activities",
  "version": "0.1.0",
  "description": "Track browser tabs per GNOME Activity",
  "permissions": ["tabs", "storage", "nativeMessaging"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_title": "GNOME Activities"
  },
  "host_permissions": ["<all_urls>"]
}
